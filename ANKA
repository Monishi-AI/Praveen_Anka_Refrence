<script>
const sections=document.querySelectorAll('section[id]');
const navItems=document.querySelectorAll('.nav-item[href^="#s"]');
const progress=document.getElementById('progress');
window.addEventListener('scroll',()=>{
  const scrollY=window.scrollY;
  const docH=document.body.scrollHeight-window.innerHeight;
  progress.style.width=Math.min(100,(scrollY/docH)*100)+'%';
  let cur='';
  sections.forEach(s=>{if(scrollY>=s.offsetTop-120)cur=s.id;});
  navItems.forEach(n=>n.classList.toggle('active',n.getAttribute('href')==='#'+cur));
});
document.querySelectorAll('a[href^="#"]').forEach(a=>{
  a.addEventListener('click',e=>{
    e.preventDefault();
    const t=document.querySelector(a.getAttribute('href'));
    if(t)t.scrollIntoView({behavior:'smooth',block:'start'});
  });
});
</script>
